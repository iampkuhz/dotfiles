#github token 用来提高 git clone 的访问限制
GITHUB_TOKEN='github_pat_***'

# 代码补全：统一由 litellm 网关提供
# 下面这些变量在 ~/.env 中已有定义，此处仅作示例占位
# AUTOCOMPLETE_API_BASE 和 AUTOCOMPLETE_MODEL 默认值由 70-ai.zsh
# 从 LITELLM_BASE_URL / LITELLM_AUTOCOMPLETE_MODEL_OPENAI 推导，
# 一般不需要显式设置。如需覆盖（例如指向本地 Ollama）才取消注释。
#
## 行内补全：指向 litellm（默认，通常不需要写）
# AUTOCOMPLETE_API_BASE=http://localhost:4000/v1
# AUTOCOMPLETE_MODEL=litellm-autocomplate-openai

