# 请把以下变量写入 ~/.env（由 zsh 启动时自动加载）。

# ===== LiteLLM 上游模型配置（LiteLLM 内部使用） =====
# 场景1：本地 LM Studio / omlx
# LITELLM_UPSTREAM_MODEL=openai/qwen/qwen3-14b
# LITELLM_UPSTREAM_BASE_URL=http://host.containers.internal:1234/v1
# LITELLM_UPSTREAM_API_KEY=lm-studio
#
# 场景2：远程 API
# LITELLM_UPSTREAM_MODEL=openai/qwen3.5-plus
# LITELLM_UPSTREAM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LITELLM_UPSTREAM_API_KEY=your-remote-api-key

LITELLM_UPSTREAM_MODEL=openai/replace-with-model-id
LITELLM_UPSTREAM_BASE_URL=https://replace-with-your-endpoint/v1
LITELLM_UPSTREAM_API_KEY=replace-with-api-key

# LiteLLM 网关访问 token（OpenClaw 调用时用这个鉴权）
LITELLM_MASTER_KEY=replace-with-a-long-random-token

# Langfuse 项目密钥（在 Langfuse Project Settings 中复制）
LANGFUSE_PUBLIC_KEY=pk-lf-replace-me
LANGFUSE_SECRET_KEY=sk-lf-replace-me

# ===== 客户端应用配置（调用 LiteLLM 本地代理） =====
# 其他应用通过以下配置连接 LiteLLM 提供的本地服务
CHAT_MODEL=chat-model
CHAT_API_BASE=http://localhost:4000/v1
CHAT_API_KEY=${LITELLM_MASTER_KEY}
