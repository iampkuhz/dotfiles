# LiteLLM 轻量代理 - 环境变量模板
# 使用说明：
# 1. 复制此文件：cp observability/litellm/.env.example ~/.env.litellm
# 2. 编辑 ~/.env.litellm，填入真实值
# 3. 启动前确保已 source ~/.env.litellm

# ==============================================================================
# [必需] LiteLLM 基础配置
# ==============================================================================

# LiteLLM 网关访问 token（客户端调用时需携带此 token）
# 生成命令：openssl rand -hex 16
LITELLM_MASTER_KEY=replace-with-a-long-random-token

# ==============================================================================
# [必需] 上游模型配置（百炼 / Qwen）
# ==============================================================================

# 百炼 OpenAI 兼容端点
BAILIAN_CODING_PLAN_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 百炼 Anthropic 兼容端点
BAILIAN_CODING_PLAN_ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 百炼 API 密钥
BAILIAN_CODING_PLAN_API_KEY=replace-with-your-bailian-api-key

# 模型名称标识（用于 LiteLLM 内部路由）
LITELLM_OPENAI_QWEN_MODEL=qwen-openai
LITELLM_ANTHROPIC_QWEN_MODEL=qwen-anthropic

# ==============================================================================
# [必需] 数据库配置（LiteLLM Proxy 必需）
# ==============================================================================

# PostgreSQL 数据库密码（默认：litellm_password）
# 建议修改为随机生成的安全密码
POSTGRES_PASSWORD=litellm_password

# PostgreSQL 数据库连接字符串
# 格式：postgresql://用户名：密码@主机：端口/数据库名
# 默认配置与 docker-compose.yml 中的 PostgreSQL 服务匹配
# 容器内使用：postgresql://litellm:litellm_password@litellm-db:5432/litellm
# 宿主机使用：postgresql://litellm:litellm_password@localhost:5432/litellm
DATABASE_URL=postgresql://litellm:litellm_password@localhost:5432/litellm

# ==============================================================================
# [可选] OpenTelemetry 配置（用于接入 Braintrust / Arize AX）
# 不接云端观测平台时可留空
# ==============================================================================

# OTel 端点（例如：https://otlp.braintrust.dev）
OTEL_EXPORTER_OTLP_ENDPOINT=

# OTel 请求头（例如：Authorization=Bearer your-api-key）
OTEL_EXPORTER_OTLP_HEADERS=

# 是否启用 Request Span（true/false）
USE_OTEL_LITELLM_REQUEST_SPAN=false
